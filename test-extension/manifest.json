{
    "manifest_version": 2,
    "name": "My Spring Extension",
    "version": "1.0",
    "permissions": [
        "tabs",
        "http://localhost:8080/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}