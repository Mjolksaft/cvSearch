{
  "manifest_version": 2,
  "name": "CV Search",
  "version": "1.0",
  "permissions": ["tabs", "http://localhost:8080/*"],
  "browser_action": {
    "default_title": "CV Search",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["http://localhost/*"],
      "js": ["content-app.js"]
    }
  ]
}
